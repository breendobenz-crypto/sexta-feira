# ============================================================
# .env.example — copie para .env e preencha
# NUNCA versione o .env real!
# ============================================================

# --- OKX API (gerar em OKX → API Management) ---
# Permissões necessárias: Trade + Read
OKX_API_KEY=coloque_sua_api_key_aqui
OKX_API_SECRET=coloque_seu_api_secret_aqui
OKX_PASSPHRASE=coloque_sua_passphrase_aqui
OKX_SIMULATED=false        # true = paper trading (sem dinheiro real)

# --- TELEGRAM ---
TELEGRAM_TOKEN=coloque_token_do_botfather
TELEGRAM_CHAT_ID=coloque_seu_chat_id
TELEGRAM_SIGNAL_GROUP=     # opcional: grupo público de sinais

# --- ELEVENLABS (voz) ---
ELEVENLABS_API_KEY=coloque_sua_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- ANTHROPIC / CLAUDE (segundo cérebro) ---
# Obtenha em: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-coloque_sua_key

# --- GOOGLE SHEETS (opcional) ---
GOOGLE_SHEET_ID=

# --- OBSIDIAN (segundo cérebro) ---
# Deixe vazio para usar pasta local ./trades/
OBSIDIAN_TRADES_PATH=trades

# --- WATCHDOG ---
WATCHDOG_RESTART_SECONDS=10
